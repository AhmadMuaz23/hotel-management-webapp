<div style="font-family: sans-serif; max-width: 600px; margin: 0 auto; padding: 40px; background-color: #fdfaf8; border-radius: 40px; border: 1px solid #f3e8df;">
  <h2 style="color: #38220f; text-transform: uppercase; font-size: 24px; font-weight: 900; letter-spacing: -0.05em; font-style: italic; margin-bottom: 20px;">
    SANCTUARY ACCESS: RECOVERY CODE
  </h2>
  
  <p style="color: #8b735b; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; line-height: 1.6;">
    Dear <%= @user.name %>,<br><br>
    We received a request to re-establish your secret key. Use the code below to finalize your recovery process.
  </p>

  <div style="margin: 40px 0; padding: 30px; background-color: #ffffff; border-radius: 24px; text-align: center; border: 1px solid #f3e8df;">
    <span style="font-size: 48px; font-weight: 900; color: #38220f; letter-spacing: 0.2em; font-style: italic;">
      <%= @code %>
    </span>
  </div>

  <p style="color: #b5a494; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; italic;">
    If you did not initiate this request, please disregard this transmission immediately. Your sanctuary remains secure.
  </p>
  
  <hr style="border: none; border-top: 1px solid #f3e8df; margin: 40px 0;">
  
  <p style="text-align: center; color: #8b735b; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.3em;">
    HAVEN HOTELS | EST. 2026
  </p>
</div>
